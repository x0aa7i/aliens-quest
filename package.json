{
	"name": "aliens-quest",
	"private": true,
	"version": "0.2.0",
	"type": "module",
	"scripts": {
		"dev": "dotenv -- velite dev & vite dev & wrangler pages dev --proxy 5173",
		"proxy": "wrangler pages dev --proxy 5173",
		"build": "velite && vite build",
		"preview": "wrangler pages dev",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --incremental --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"db:seed:local": "wrangler d1 execute aliensquest_db --local --file=scripts/seed.sql",
		"db:seed:remote": "wrangler d1 execute aliensquest_db --file=scripts/seed.sql",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:migrate:local": "wrangler d1 migrations apply aliensquest_db --local --config wrangler.jsonc",
		"db:migrate:remote": "wrangler d1 migrations apply aliensquest_db --remote --config wrangler.jsonc",
		"db:backup": "wrangler d1 export aliensquest_db --output backup-prod.sql --remote",
		"deploy": "pnpm run build && wrangler pages deploy",
		"cf-typegen": "wrangler types && mv worker-configuration.d.ts src/"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260305.1",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^10.0.1",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@iconify-json/bx": "^1.2.3",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^0.577.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "^25.3.5",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"dotenv-cli": "^11.0.0",
		"drizzle-kit": "^0.31.9",
		"drizzle-orm": "^0.45.1",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.4.0",
		"gray-matter": "^4.0.3",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-slug": "^6.0.0",
		"remark-directive": "^4.0.0",
		"svelte": "^5.53.7",
		"svelte-check": "^4.4.4",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"unist-util-visit": "^5.1.0",
		"unplugin-icons": "^23.0.1",
		"vaul-svelte": "1.0.0-next.6",
		"velite": "^0.3.1",
		"vite": "^7.3.1",
		"wrangler": "^4.71.0"
	},
	"engines": {
		"node": ">= 20.0.0",
		"pnpm": ">= 8.0.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"workerd"
		]
	},
	"dependencies": {
		"@fingerprintjs/fingerprintjs": "^5.1.0",
		"@fontsource-variable/ibm-plex-sans": "^5.2.8",
		"@fontsource/chakra-petch": "^5.2.7"
	}
}
